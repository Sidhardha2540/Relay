{
  "_comment": "Add this block to ~/.claude/mcp_config.json (or merge with existing mcpServers).",
  "mcpServers": {
    "coord": {
      "command": "python",
      "args": ["/ABSOLUTE/PATH/TO/coord/mcp-shim/shim.py"],
      "env": {
        "COORD_AGENT_ID": "claude-code",
        "COORD_BASE_URL": "http://127.0.0.1:49152"
      }
    }
  }
}
